<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- Stylish Top Bar (Baby Pink) -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#F48FB1"
        app:title="תמיד בשביל התלמיד"
        app:titleTextColor="#FFFFFF"
        app:menu="@menu/home_menu"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <!-- Baby Yellow Star Icon -->
        <ImageView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginBottom="16dp"
            android:src="@android:drawable/btn_star_big_on"
            app:tint="#FFF9C4" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="שלום!\nמה נלמד היום?"
            android:textColor="#F48FB1"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="40dp" />

        <!-- Buttons with icons and rounded corners -->
        <Button
            android:id="@+id/QesBtn"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F48FB1"
            android:text="מאגר בחינות ופתרונות"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_menu_sort_by_size"
            app:iconTint="#FFF9C4" />

        <Button
            android:id="@+id/AIBtn"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:layout_marginBottom="16dp"
            android:backgroundTint="#F48FB1"
            android:text="שיחה עם מורה חכם"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_menu_edit"
            app:iconTint="#FFF9C4" />

        <Button
            android:id="@+id/PhotoBtn"
            android:layout_width="match_parent"
            android:layout_height="65dp"
            android:backgroundTint="#F48FB1"
            android:text="פתרון באמצעות תמונה"
            app:cornerRadius="20dp"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconTint="#FFF9C4" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>